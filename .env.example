# ---------------------------------------------------------------------------
# FlowForge environment configuration
# Copy this file to `.env` and fill in the values you need.
# ---------------------------------------------------------------------------

# Which model backend the app talks to.
#   fireworks -> hosted base/dev model on Fireworks (development)
#   amd       -> your fine-tuned model served with vLLM on the AMD GPU pod (demo/judging)
MODEL_MODE=fireworks

# --- Fireworks (MODEL_MODE=fireworks) --------------------------------------
# Create the key at https://app.fireworks.ai (API Keys). If every request
# returns 404 "Model not found", the KEY itself is invalid - regenerate it.
FIREWORKS_API_KEY=fw_your_key_here
# Pick a Gemma model id that exists on Fireworks serverless for your account
# (check https://app.fireworks.ai/models), e.g. a gemma-4 instruct variant:
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-e4b
# Override only if Fireworks changes its endpoint:
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# --- AMD vLLM endpoint (MODEL_MODE=amd) ------------------------------------
# OpenAI-compatible base_url of your vLLM server, e.g.
#   http://localhost:8000/v1        (via SSH tunnel from the GPU pod)
#   http://<pod-ip>:8000/v1         (open port + API key)
AMD_MODEL_ENDPOINT=http://localhost:8000/v1
# Model name must match vLLM's --served-model-name (default: flowforge)
AMD_MODEL_NAME=flowforge
# Bearer key if you served vLLM with --api-key (optional)
AMD_MODEL_API_KEY=

# --- n8n management API (self-hosted) --------------------------------------
# Inside docker-compose the backend reaches n8n at http://n8n:5678/api/v1
# From your host machine it is http://localhost:5678/api/v1
N8N_API_URL=http://localhost:5678/api/v1
# Create this in the n8n UI: Settings -> n8n API -> Create an API key
N8N_API_KEY=

# n8n editor base URL used to build clickable "open in n8n" links for the UI
N8N_EDITOR_URL=http://localhost:5678
